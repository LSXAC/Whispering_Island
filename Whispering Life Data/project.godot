; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Whispering Island"
config/version="1.0.0.5"
run/main_scene="res://Menus/main_menu.tscn"
config/features=PackedStringArray("4.3", "C#", "Forward Plus")
run/max_fps=60
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="res://Sprites/Monster_Island.png"

[autoload]

GlobalFunctions="*res://Scripts/GlobalFunctions.cs"
Database="*res://Scripts/Database.cs"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"

[dialogue_manager]

general/balloon_path="res://Dialogues/Balloon.tscn"
general/uses_dotnet=true
general/default_csv_locale="de"
general/include_all_responses=true

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/mode=4
window/size/resizable=false
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Whispering Life"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

[global_group]

Island_Properties="Echt Main Node of an Island"

[gui]

timers/tooltip_delay_sec=0.2

